---
import { Image } from 'astro:assets';
import SectionEyebrow from './SectionEyebrow.astro';
import review1 from '@assets/images/reviews/review-1.jpg';
import review2 from '@assets/images/reviews/review-2.jpg';
import review3 from '@assets/images/reviews/review-3.jpg';
import review4 from '@assets/images/reviews/review-4.jpg';

const reviews = [review1, review2, review3, review4];
---
<section class="bg-white py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <SectionEyebrow num="06" label="Що кажуть" />
    <h2 class="font-serif text-3xl font-bold text-navy-900 md:text-4xl">
      Відгуки тих, хто вже пройшов
    </h2>
    <p class="mt-4 text-navy-600">Справжні скріни відгуків із директу.</p>
    <div class="mt-10 gap-6 sm:columns-2 [&>*]:mb-6">
      {reviews.map((src, i) => (
        <Image
          src={src}
          alt={`Відгук ${i + 1}`}
          widths={[400, 600, 800]}
          sizes="(max-width: 640px) 100vw, 50vw"
          loading="lazy"
          class="w-full rounded-xl border border-navy-100 shadow-sm"
        />
      ))}
    </div>
  </div>
</section>

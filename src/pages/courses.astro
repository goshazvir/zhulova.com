---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Курси - Вікторія Жульова"
  description="Практичні курси з особистісного розвитку, трансформації мислення та досягнення цілей від сертифікованого коуча Вікторії Жульової"
>
  <Header variant="main" />

  <main class="min-h-screen bg-white pt-32 pb-20">
    <!-- Hero Section -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-16">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-bold text-navy-900 mb-6">
        Мої курси
      </h1>
      <p class="text-xl md:text-2xl text-navy-700 max-w-3xl leading-relaxed">
        Практичні інструменти для самостійного розвитку
      </p>
    </section>

    <!-- Courses Grid -->
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <article class="relative bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-shadow border border-navy-100">
          <div class="bg-gradient-to-br from-navy-800 to-navy-900 h-48 flex items-center justify-center">
            <span class="font-serif text-3xl font-bold text-gold-400">Опора на себе</span>
          </div>
          <div class="p-6">
            <h2 class="text-2xl font-serif font-bold text-navy-900 mb-3">
              Опора на себе
            </h2>
            <p class="text-navy-700 mb-6 leading-relaxed">
              3-денний міні-курс: практики спокою, зменшення внутрішнього критика і дорослий план, від якого голова не болить.
            </p>
            <a
              href="/courses/opora"
              class="inline-block bg-navy-900 text-white px-6 py-3 rounded-lg font-medium hover:bg-navy-800 transition-colors after:absolute after:inset-0 after:content-['']"
              aria-label="Опора на себе — дізнатись більше"
            >
              Дізнатись більше
            </a>
          </div>
        </article>
      </div>
    </section>
  </main>

  <Footer variant="legal" />
</BaseLayout>
